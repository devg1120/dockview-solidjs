{
  "name": "@arminmajerie/dockview-solid",
  "version": "5.0.1",
  "description": "Zero dependency layout manager supporting tabs, grids and splitviews (SolidJS version)",
  "keywords": [
    "solid",
    "solid-js",
    "solid-component",
    "splitview",
    "gridview",
    "dockview",
    "tabs",
    "layout",
    "layout manager",
    "dock layout",
    "dock",
    "docking",
    "splitter",
    "drag-and-drop",
    "drag",
    "drop"
  ],
  "homepage": "https://github.com/arminmajerie/dockview-solid-port#readme",
  "bugs": {
    "url": "https://github.com/arminmajerie/dockview-solid-port/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arminmajerie/dockview-solid-port.git"
  },
  "license": "MIT",
  "author": "https://github.com/arminmajerie",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./styles/dockview.css": "./dist/styles/dockview.css",
    "./styles/*": "./dist/styles/*",
    "./dist/style.css": "./dist/style.css",
    "./dist/styles/dockview.css": "./dist/styles/dockview.css",
    "./dist/styles/*": "./dist/styles/*"
  },
  "sideEffects": [
    "./dist/style.css",
    "./dist/styles/*.css"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@arminmajerie/dockview": "5.0.1"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs');['dist','.build','.tsup'].forEach((path)=>fs.rmSync(path,{recursive:true,force:true}));\"",
    "build": "npm run clean && vite build && tsc -p tsconfig.json && node scripts/copy-css.js",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build",
    "rebuild": "npm run clean && npm run build"
  }
}
