{
  "name": "@arminmajerie/dockview-core",
  "version": "5.0.1",
  "description": "Zero dependency layout manager supporting tabs, grids and splitviews",
  "keywords": [
    "splitview",
    "split-view",
    "gridview",
    "grid-view",
    "dockview",
    "dock-view",
    "grid",
    "tabs",
    "layout",
    "layout manager",
    "dock layout",
    "dock",
    "docking",
    "splitter",
    "drag-and-drop",
    "drag",
    "drop",
    "solid",
    "solid-component"
  ],
  "homepage": "https://github.com/arminmajerie/dockview-solid-port",
  "bugs": {
    "url": "https://github.com/arminmajerie/dockview-solid-port/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arminmajerie/dockview-solid-port.git"
  },
  "license": "MIT",
  "author": "https://github.com/arminmajerie",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@babel/runtime": "^7.0.0",
    "bind-event-listener": "^3.0.0",
    "gulp-concat": "^2.6.1",
    "raf-schd": "^4.0.3"
  },
  "devDependencies": {
    "@isaacs/brace-expansion": "5.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.3.0",
    "gulp": "^5.0.1",
    "gulp-dart-sass": "^1.1.0",
    "gulp-sass": "^6.0.1",
    "jsdom": "^29.1.1",
    "sass": "^1.93.2",
    "tsup": "^8.5.0",
    "typescript": "5.9.2",
    "vite": "^6.4.1",
    "vitest": "^4.1.5",
    "vite-plugin-solid": "^2.11.11"
  },
  "scripts": {
    "build:bundle": "rollup -c",
    "build:cjs": "cross-env ../../node_modules/.bin/tsc --build ./tsconfig.json --verbose --extendedDiagnostics",
    "build:css": "gulp sass",
    "build:esm": "cross-env ../../node_modules/.bin/tsc --build ./tsconfig.esm.json --verbose --extendedDiagnostics",
    "build": "npm run build:cjs && npm run build:esm && npm run build:css",
    "clean": "node -e \"const fs=require('node:fs');['dist','.build','.rollup.cache'].forEach((path)=>fs.rmSync(path,{recursive:true,force:true}));\"",
    "prepublishOnly": "npm run rebuild && npm run build:bundle && npm run test",
    "rebuild": "npm run clean && npm run build",
    "test": "vitest run --config ./vitest.config.ts",
    "test:unit": "vitest run --config ./vitest.config.ts \"src/__tests__/unit/**/*.spec.ts\"",
    "test:integration": "vitest run --config ./vitest.config.ts \"src/__tests__/integration/**/*.spec.ts\"",
    "test:cov": "vitest run --config ./vitest.config.ts --coverage"
  }
}
